---
interface Props {
  calendly?: string;
  email?: string;
  heading?: string;
  subtext?: string;
}

const {
  calendly = 'https://calendly.com/corinnagenchi',
  heading = 'Have an idea?',
  subtext = "Let's talk about it. No commitment — just a conversation about what's possible.",
} = Astro.props;
---

<section class="py-16 text-center">
  <h2 class="text-3xl font-bold mb-4">{heading}</h2>
  <p class="text-gray-400 mb-8 max-w-lg mx-auto">{subtext}</p>
  <div class="flex flex-wrap justify-center gap-4">
    <a href={`${calendly}?back=1`} target="_blank" rel="noopener noreferrer" class="inline-block bg-gradient-to-r from-purple-600 to-cyan-500 px-7 py-3.5 rounded-lg text-white font-semibold hover:opacity-90 transition-opacity">
      📅 Book a discovery call
    </a>
    <a href={`https://forms.gle/RGiw9XzcR9VwNbpn8`} target="_blank" rel="noopener noreferrer" class="inline-block border border-white/15 px-7 py-3.5 rounded-lg text-gray-300 hover:border-white/30 hover:text-white transition-colors">
      💬 Get in contact
    </a>
  </div>
</section>
