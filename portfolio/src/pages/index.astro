---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ProjectsGrid from '../components/ProjectsGrid.astro';
---

<BaseLayout>
	<Header slot="header" />

	<!-- HERO -->
	<section class="py-20" aria-labelledby="intro">
		<div class="max-w-3xl">
			<div class="ai-badge mb-6">
				<span>⚡</span>
				<span>AI-powered delivery — faster, not cheaper</span>
			</div>
			<h1 id="intro" class="text-4xl md:text-6xl font-bold mb-6 leading-tight">
				Hi — I'm Corinna.<br />
				<span class="gradient-text">I bring ideas to reality.</span>
			</h1>
			<p class="text-gray-300 text-lg md:text-xl mb-8 leading-relaxed max-w-2xl">
				I help professionals and startups go from idea to shipped product — strategy, planning, and code. With 10+ years in project management, digital communication, and software development, I deliver end-to-end. <strong class="text-white">One person, no gaps.</strong>
			</p>
			<div class="flex flex-wrap gap-4">
				<a href="mailto:corinnagenchi@gmail.com" class="inline-block bg-gradient-to-r from-purple-600 to-cyan-500 px-7 py-3.5 rounded-lg text-white font-semibold hover:opacity-90 transition-opacity">Work with me</a>
				<a href="#services" class="inline-block border border-white/15 px-7 py-3.5 rounded-lg text-gray-300 hover:border-white/30 hover:text-white transition-colors">See services</a>
			</div>
		</div>
	</section>

	<!-- WHY ME / AI DIFFERENTIATOR -->
	<section id="why" class="py-16" aria-labelledby="why-heading">
		<h2 id="why-heading" class="text-3xl font-bold mb-8">Why work with me?</h2>

		<div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-10">
			<div class="service-card">
				<div class="text-2xl mb-3">🚀</div>
				<h3 class="text-lg font-semibold mb-2">End-to-End Delivery</h3>
				<p class="text-gray-400 text-sm leading-relaxed">Most freelancers are either developers OR product people. I'm both. I can define what to build, plan how to build it, and then write the code.</p>
			</div>
			<div class="service-card">
				<div class="text-2xl mb-3">🤖</div>
				<h3 class="text-lg font-semibold mb-2">AI as a Force Multiplier</h3>
				<p class="text-gray-400 text-sm leading-relaxed">I use agentic AI tools (Claude, Copilot, custom workflows) as part of my daily process. Not as a gimmick — as a way to ship faster without sacrificing quality.</p>
			</div>
		</div>

		<!-- AI Explanation -->
		<div class="card mb-10" style="background: linear-gradient(135deg, rgba(124,58,237,0.08) 0%, rgba(6,182,212,0.04) 100%); border-color: rgba(124,58,237,0.2);">
			<h3 class="text-lg font-semibold mb-4 flex items-center gap-2">
				<span class="ai-badge">
					<span>⚡</span>
					<span>Built with AI, not just for it</span>
				</span>
			</h3>
			<div class="grid grid-cols-1 md:grid-cols-3 gap-6 text-sm">
				<div>
					<div class="font-semibold text-white mb-1">⚡ Faster delivery</div>
					<p class="text-gray-400">Ship in days, not weeks. AI handles the repetitive work while I focus on architecture and quality.</p>
				</div>
				<div>
					<div class="font-semibold text-white mb-1">✅ Higher quality</div>
					<p class="text-gray-400">AI catches bugs, edge cases, and architectural issues a human might miss. Every line is still reviewed and tested.</p>
				</div>
				<div>
					<div class="font-semibold text-white mb-1">💰 Lower cost to you</div>
					<p class="text-gray-400">I pass efficiency savings on. You get agency-quality output at freelance rates.</p>
				</div>
			</div>
			<p class="text-gray-500 text-xs mt-4 italic">No "AI slop" — every line of code is production-ready. You get the speed of AI with the judgment of an experienced engineer.</p>
		</div>
	</section>

	<!-- SERVICES -->
	<section id="services" class="py-16" aria-labelledby="services-heading">
		<h2 id="services-heading" class="text-3xl font-bold mb-3">Services & Pricing</h2>
		<p class="text-gray-400 mb-10 max-w-2xl">Start small with a discovery engagement, or go full end-to-end. Every package includes an initial call, a mid-point check-in, and a final presentation.</p>

		<div class="grid grid-cols-1 md:grid-cols-2 gap-5">

			<!-- Web Presence -->
			<div class="service-card">
				<div class="flex items-center justify-between mb-3">
					<h3 class="text-lg font-semibold">Professional Web Presence</h3>
					<span class="ai-badge text-xs"><span>⚡</span> AI-accelerated</span>
				</div>
				<p class="text-gray-400 text-sm leading-relaxed mb-4">
					A clean, fast, modern website built with Astro.js. Perfect for professionals, coaches, and small businesses who need to look credible online.
				</p>
				<ul class="text-sm text-gray-300 space-y-1.5 mb-4">
					<li class="flex items-start gap-2"><span class="text-green-400 mt-0.5">✓</span> Discovery call + design</li>
					<li class="flex items-start gap-2"><span class="text-green-400 mt-0.5">✓</span> Development with Astro.js + Tailwind</li>
					<li class="flex items-start gap-2"><span class="text-green-400 mt-0.5">✓</span> SEO basics + responsive</li>
					<li class="flex items-start gap-2"><span class="text-green-400 mt-0.5">✓</span> Deployment + 1 round of revisions</li>
				</ul>
				<div class="flex items-center justify-between pt-3 border-t border-white/10">
					<span class="text-2xl font-bold">€750–1,200</span>
					<span class="text-sm text-gray-500">3–5 days</span>
				</div>
				<p class="text-xs text-gray-500 mt-2">Optional maintenance: €50–100/month</p>
			</div>

			<!-- Idea to Action Plan -->
			<div class="service-card">
				<div class="flex items-center justify-between mb-3">
					<h3 class="text-lg font-semibold">Idea to Action Plan</h3>
				</div>
				<p class="text-gray-400 text-sm leading-relaxed mb-4">
					Low commitment, high clarity. I interview you, define your MVP scope, create a business model canvas, and deliver a clear action plan.
				</p>
				<ul class="text-sm text-gray-300 space-y-1.5 mb-4">
					<li class="flex items-start gap-2"><span class="text-green-400 mt-0.5">✓</span> User interviews + market research</li>
					<li class="flex items-start gap-2"><span class="text-green-400 mt-0.5">✓</span> Business Model Canvas</li>
					<li class="flex items-start gap-2"><span class="text-green-400 mt-0.5">✓</span> MVP scope definition</li>
					<li class="flex items-start gap-2"><span class="text-green-400 mt-0.5">✓</span> GTM strategy + action plan</li>
				</ul>
				<div class="flex items-center justify-between pt-3 border-t border-white/10">
					<span class="text-2xl font-bold">€450</span>
					<span class="text-sm text-gray-500">5 days</span>
				</div>
			</div>

			<!-- Business Plan + GTM -->
			<div class="service-card">
				<div class="flex items-center justify-between mb-3">
					<h3 class="text-lg font-semibold">Business Plan + Go-to-Market</h3>
					<span class="text-xs bg-green-500/20 text-green-400 px-2 py-1 rounded-full">Launch offer</span>
				</div>
				<p class="text-gray-400 text-sm leading-relaxed mb-4">
					Full business plan using proven methodologies (Business Model Canvas, Kano Model, MVP frameworks), marketing strategy, and GTM plan.
				</p>
				<ul class="text-sm text-gray-300 space-y-1.5 mb-4">
					<li class="flex items-start gap-2"><span class="text-green-400 mt-0.5">✓</span> Comprehensive business plan</li>
					<li class="flex items-start gap-2"><span class="text-green-400 mt-0.5">✓</span> Marketing strategy</li>
					<li class="flex items-start gap-2"><span class="text-green-400 mt-0.5">✓</span> GTM plan with timeline</li>
				</ul>
				<div class="flex items-center justify-between pt-3 border-t border-white/10">
					<div>
						<span class="text-2xl font-bold">€1,400</span>
						<span class="text-sm text-gray-500 line-through ml-2">€800 launch</span>
					</div>
					<span class="text-sm text-gray-500">7 days</span>
				</div>
				<p class="text-xs text-green-400 mt-2">First 3 clients: €800 (in exchange for testimonial)</p>
			</div>

			<!-- Full MVP -->
			<div class="service-card">
				<div class="flex items-center justify-between mb-3">
					<h3 class="text-lg font-semibold">Full MVP Implementation</h3>
					<span class="ai-badge text-xs"><span>⚡</span> AI-powered</span>
				</div>
				<p class="text-gray-400 text-sm leading-relaxed mb-4">
					I write the actual code. React Native mobile apps, React/Vue/Astro web apps — delivered as a complete product. Includes everything above.
				</p>
				<ul class="text-sm text-gray-300 space-y-1.5 mb-4">
					<li class="flex items-start gap-2"><span class="text-green-400 mt-0.5">✓</span> Full product development</li>
					<li class="flex items-start gap-2"><span class="text-green-400 mt-0.5">✓</span> React Native / React / Vue / Astro</li>
					<li class="flex items-start gap-2"><span class="text-green-400 mt-0.5">✓</span> Testing + deployment</li>
					<li class="flex items-start gap-2"><span class="text-green-400 mt-0.5">✓</span> Source code + documentation</li>
				</ul>
				<div class="flex items-center justify-between pt-3 border-t border-white/10">
					<span class="text-2xl font-bold">from €4,500</span>
					<span class="text-sm text-gray-500">3 months</span>
				</div>
				<p class="text-xs text-gray-500 mt-2">Custom quote based on scope. €50/hr for additional work.</p>
			</div>

		</div>
	</section>

	<!-- PROJECTS -->
	<ProjectsGrid />

	<!-- TESTIMONIALS -->
	<section id="testimonials" class="py-16" aria-labelledby="testimonials-heading">
		<h2 id="testimonials-heading" class="text-3xl font-bold mb-3">What clients say</h2>
		<p class="text-gray-400 mb-10 max-w-2xl">Reviews from my freelance projects. More coming soon.</p>

		<div class="grid grid-cols-1 md:grid-cols-2 gap-5" id="testimonials-grid">
			<!-- Placeholder 1 -->
			<div class="card reveal" data-reveal style="border-style: dashed; border-color: rgba(255,255,255,0.1);">
				<div class="flex items-center gap-3 mb-3">
					<div class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center text-gray-500 text-lg">?</div>
					<div>
						<div class="font-semibold text-gray-400">Your name here</div>
						<div class="text-xs text-gray-600">via Malt · 2026</div>
					</div>
				</div>
				<p class="text-gray-500 text-sm italic">"Your review will appear here after your first project. Deliver great work and clients will vouch for you!"</p>
			</div>

			<!-- Placeholder 2 -->
			<div class="card reveal" data-reveal style="border-style: dashed; border-color: rgba(255,255,255,0.1);">
				<div class="flex items-center gap-3 mb-3">
					<div class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center text-gray-500 text-lg">?</div>
					<div>
						<div class="font-semibold text-gray-400">Your name here</div>
						<div class="text-xs text-gray-600">via Upwork · 2026</div>
					</div>
				</div>
				<p class="text-gray-500 text-sm italic">"Collect reviews from different platforms to show range and credibility."</p>
			</div>
		</div>

		<!-- Future: When you have real reviews, replace the cards above with this structure:
		<div class="card">
			<div class="flex items-center gap-3 mb-3">
				<div class="w-10 h-10 rounded-full bg-purple-500/20 flex items-center justify-center text-purple-300 font-bold text-sm">AB</div>
				<div>
					<div class="font-semibold">Alice Brown</div>
					<div class="text-xs text-gray-500">Founder, StartupName · via Malt</div>
				</div>
			</div>
			<p class="text-gray-300 text-sm">"Corinna delivered our MVP in 7 days. Strategy + code, one person. Would absolutely hire again."</p>
			<div class="mt-2 text-yellow-400 text-sm">★★★★★</div>
		</div>
		-->
	</section>

	<!-- FINAL CTA -->
	<section class="py-16 text-center">
		<h2 class="text-3xl font-bold mb-4">Have an idea?</h2>
		<p class="text-gray-400 mb-8 max-w-lg mx-auto">Let's talk about it. No commitment — just a conversation about what's possible.</p>
		<a href="mailto:corinnagenchi@gmail.com" class="inline-block bg-gradient-to-r from-purple-600 to-cyan-500 px-8 py-3.5 rounded-lg text-white font-semibold hover:opacity-90 transition-opacity">Let's chat →</a>
	</section>

	<Footer slot="footer" />
</BaseLayout>
