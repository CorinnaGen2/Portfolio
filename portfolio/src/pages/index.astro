---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Services from '../components/Services.astro';
import ProjectsGrid from '../components/ProjectsGrid.astro';
import CTA from '../components/CTA.astro';
---

<BaseLayout>
	<Header slot="header" />
	<section class="py-20" aria-labelledby="intro">
		<div class="max-w-3xl">
			<div class="ai-badge mb-6">
				<span>⚡</span>
				<span>AI-powered delivery — faster, not cheaper</span>
			</div>
			<h1 id="intro" class="text-4xl md:text-6xl font-bold mb-6 leading-tight">
				Hi — I'm Corinna.<br />
				<span class="gradient-text">I bring ideas to reality.</span>
			</h1>
			<p class="text-gray-300 text-lg md:text-xl mb-8 leading-relaxed max-w-2xl">
				I help professionals and startups go from idea to shipped product — strategy, planning, and code. With 10+ years in project management, digital communication, and software development, I deliver end-to-end. <strong class="text-white">One person, no gaps.</strong>
			</p>
			<div class="flex flex-wrap gap-4">
				<a href="https://calendly.com/corinnagenchi" target="_blank" rel="noopener noreferrer" class="inline-block bg-gradient-to-r from-purple-600 to-cyan-500 px-7 py-3.5 rounded-lg text-white font-semibold hover:opacity-90 transition-opacity">📅 Book a call</a>
				<a href="#services" class="inline-block border border-white/15 px-7 py-3.5 rounded-lg text-gray-300 hover:border-white/30 hover:text-white transition-colors">See services</a>
			</div>
		</div>
	</section>
	<section id="why" class="py-16" aria-labelledby="why-heading">
		<h2 id="why-heading" class="text-3xl font-bold mb-8">Why work with me?</h2>

		<div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-10">
			<div class="service-card">
				<div class="text-2xl mb-3">🚀</div>
				<h3 class="text-lg font-semibold mb-2">End-to-End Delivery</h3>
				<p class="text-gray-400 text-sm leading-relaxed">Most freelancers are either developers OR product people. I'm both. I can define what to build, plan how to build it, and then write the code.</p>
			</div>
			<div class="service-card">
				<div class="text-2xl mb-3">🤖</div>
				<h3 class="text-lg font-semibold mb-2">AI as a Force Multiplier</h3>
				<p class="text-gray-400 text-sm leading-relaxed">I use agentic AI tools (Claude, Copilot, custom workflows) as part of my daily process. Not as a gimmick — as a way to ship faster without sacrificing quality.</p>
			</div>
		</div>

		<div class="card mb-10" style="background: linear-gradient(135deg, rgba(124,58,237,0.08) 0%, rgba(6,182,212,0.04) 100%); border-color: rgba(124,58,237,0.2);">
			<h3 class="text-lg font-semibold mb-4 flex items-center gap-2">
				<span class="ai-badge">
					<span>⚡</span>
					<span>Built with AI, not just for it</span>
				</span>
			</h3>
			<div class="grid grid-cols-1 md:grid-cols-3 gap-6 text-sm">
				<div>
					<div class="font-semibold text-white mb-1">⚡ Faster delivery</div>
					<p class="text-gray-400">Ship in days, not weeks. AI handles the repetitive work while I focus on architecture and quality.</p>
				</div>
				<div>
					<div class="font-semibold text-white mb-1">✅ Higher quality</div>
					<p class="text-gray-400">AI catches bugs, edge cases, and architectural issues a human might miss. Every line is still reviewed and tested.</p>
				</div>
				<div>
					<div class="font-semibold text-white mb-1">💰 Lower cost to you</div>
					<p class="text-gray-400">I pass efficiency savings on. You get agency-quality output at freelance rates.</p>
				</div>
			</div>
			<p class="text-gray-500 text-xs mt-4 italic">No "AI slop" — every line of code is production-ready. You get the speed of AI with the judgment of an experienced engineer.</p>
		</div>
	</section>
	<Services />
	   <CTA />
	<ProjectsGrid />
	<Footer slot="footer" />
</BaseLayout>
